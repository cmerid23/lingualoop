# Always install devDependencies even when NODE_ENV=production.
# Railway/Nixpacks sets NODE_ENV=production during build, which makes pnpm
# skip dev deps by default — but we need typescript + vite present at
# build time to run `tsc && vite build`. The build artifact (dist/) is
# what's served at runtime, not node_modules, so this only inflates the
# build image, not the running container's footprint.
production=false
