# LinguaLoop env vars
# Copy to .env.local and fill in. Never commit .env.local.

# Required for AI tutor + lesson generation
# Get a key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Optional — picture associations. Free tiers cover MVP usage.
# Unsplash:  https://unsplash.com/developers   (50 req/hr free)
# Pexels:    https://www.pexels.com/api/        (200 req/hr free, used as fallback)
VITE_UNSPLASH_ACCESS_KEY=
VITE_PEXELS_API_KEY=

# App metadata
VITE_APP_NAME=LinguaLoop
VITE_APP_VERSION=0.1.0
