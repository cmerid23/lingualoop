PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgres://user:password@localhost:5432/lingualoop
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-32-byte-random-hex-string

# Stripe — get these from https://dashboard.stripe.com
# Use test-mode keys (sk_test_, price_test_) until you're ready for live billing.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
# Stripe CLI: `stripe listen --forward-to localhost:3001/api/stripe/webhook`
# prints this value. In prod, get it from the webhook endpoint settings.
STRIPE_WEBHOOK_SECRET=whsec_...
